# -----------------------------------------------------------------------------
# neu-rix environment variables
# Copy this file to `.env.local` and fill in real values.
# -----------------------------------------------------------------------------

# --- Public (exposed to the browser) -----------------------------------------
NEXT_PUBLIC_APP_NAME=neu-rix
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Analytics / telemetry (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ENABLE_TELEMETRY=false

# --- Server-side secrets ------------------------------------------------------
# Generate a long random string, e.g. `openssl rand -base64 48`
# NEVER commit the real value to git. This placeholder will fail in production.
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-48
NEXTAUTH_URL=http://localhost:3000

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# --- AI providers -------------------------------------------------------------
# Leave empty to run jobs in mock mode (no external calls).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Fallback/default provider: openai | anthropic | mock
AI_DEFAULT_PROVIDER=mock

# --- Stripe -------------------------------------------------------------------
# Grab from https://dashboard.stripe.com/apikeys (test mode for development)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe price IDs created in the dashboard for each plan
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
# Optional GPU rental plan price IDs (Phase 2 — the /api/gpu/rent route uses
# price_data inline so these are not required, but kept here for dashboards
# and future migration to Stripe subscription metering).
STRIPE_PRICE_GPU_STARTER=
STRIPE_PRICE_GPU_CREATIVE=
STRIPE_PRICE_GPU_PRO=

# --- Firebase -----------------------------------------------------------------
# Grab from Firebase console → Project settings → Your apps → Web app config.
# Leave empty to disable the Firebase client (lib/firebase.js returns null).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- GPU Cloud (Phase 2) ------------------------------------------------------
# Upstream GPU provider (RunPod / Vast.ai). Leave empty to run the whole rental
# flow in mock mode (no real pods are provisioned).
RUNPOD_API_KEY=
# HMAC secret used to verify RunPod webhook payloads at /api/gpu/webhook.
RUNPOD_WEBHOOK_SECRET=
# Secret used to sign Jupyter access tokens. Falls back to NEXTAUTH_SECRET.
GPU_ACCESS_SECRET=
